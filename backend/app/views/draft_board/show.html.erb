<div class="draft-board-layout">

  <!-- Team Budgets Sidebar -->
  <div class="draft-board-sidebar">
    <div class="card">
      <h3 class="card-title">Team Budgets</h3>
      <div id="team-budgets">
        <%= render partial: "draft_board/team_budgets", locals: { teams: @teams } %>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="draft-board-main">

    <!-- Player Database -->
    <% active_positions = (@league.roster_config || {}).select { |_, slots| slots.to_i > 0 }.keys %>
    <div class="card mb-3" data-controller="draft-modal" data-draft-modal-active-positions-value="<%= active_positions.to_json %>">
      <h3 class="card-title">Player Database</h3>

      <%= form_with url: league_league_draft_board_path(@league), method: :get, data: { turbo_frame: "_top" } do |f| %>

        <div class="grid grid-4 mb-3">
          <div class="form-group">
            <%= f.label :search, "Search Player" %>
            <%= f.search_field :search, value: params[:search], placeholder: "Player name...",
                data: { controller: "debounced-search", action: "input->debounced-search#search" } %>
          </div>

          <div class="form-group">
            <%= f.label :position, "Position" %>
            <%= f.select :position, options_for_select([
              ["All Positions", ""],
              ["Catcher (C)", "C"],
              ["First Base (1B)", "1B"],
              ["Second Base (2B)", "2B"],
              ["Third Base (3B)", "3B"],
              ["Shortstop (SS)", "SS"],
              ["Corner Infield (CI)", "CI"],
              ["Middle Infield (MI)", "MI"],
              ["Outfield (OF)", "OF"],
              ["Utility (UTIL)", "UTIL"],
              ["Starting Pitcher (SP)", "SP"],
              ["Relief Pitcher (RP)", "RP"],
              ["Pitcher (P)", "P"]
            ], params[:position]), {}, { class: "form-control", onchange: "this.form.requestSubmit()" } %>
          </div>

          <div class="form-group">
            <%= f.label :drafted, "Status" %>
            <%= f.select :drafted, options_for_select([
              ["All Players", ""],
              ["Available Only", "false"],
              ["Drafted Only", "true"]
            ], params.key?(:drafted) ? params[:drafted] : "false"), {}, { class: "form-control", onchange: "this.form.requestSubmit()" } %>
          </div>

          <div class="form-group">
            <%= f.label :min_value, "Min Value ($)" %>
            <%= f.number_field :min_value, value: params[:min_value], placeholder: "e.g. 10", step: "any", min: 0,
                class: "form-control",
                data: { controller: "debounced-search", action: "input->debounced-search#search" } %>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <%= link_to "Clear Filters", league_league_draft_board_path(@league, drafted: "false"), class: "btn btn-sm" %>

          <div class="form-group" style="margin-bottom: 0; margin-left: 1rem;">
            <%= f.check_box :interested, { checked: params[:interested] == "true", onchange: "this.form.requestSubmit()" }, "true", "false" %>
            <%= f.label :interested, "Interested Only", style: "display: inline; margin-left: 0.25rem; font-weight: normal;" %>
          </div>

          <div class="form-group" style="margin-bottom: 0; margin-left: 1rem;">
            <%= f.check_box :multi_position, { checked: params[:multi_position] == "true", onchange: "this.form.requestSubmit()" }, "true", "false" %>
            <%= f.label :multi_position, "Multi-Position Only", style: "display: inline; margin-left: 0.25rem; font-weight: normal;" %>
          </div>
        </div>
      <% end %>

      <div class="mt-3">
        <p class="text-muted mb-2"><%= @players.count %> players found</p>

        <div style="max-height: 1460px; overflow-y: auto; overflow-x: auto;">
          <%
            current_sort = params[:sort]
            current_direction = params[:direction]

            # Lambda captures current filter params so sort links preserve all filters
            sort_link = ->(column, label) do
              direction = (current_sort == column && current_direction == 'desc') ? 'asc' : 'desc'
              arrow = if current_sort == column
                current_direction == 'asc' ? ' ↑' : ' ↓'
              else
                ''
              end

              link_params = { sort: column, direction: direction }
              link_params[:search] = params[:search] if params[:search].present?
              link_params[:position] = params[:position] if params[:position].present?
              link_params[:drafted] = params[:drafted].nil? ? "false" : params[:drafted]
              link_params[:interested] = params[:interested] if params[:interested] == "true"
              link_params[:multi_position] = params[:multi_position] if params[:multi_position] == "true"
              link_params[:min_value] = params[:min_value] if params[:min_value].present?

              link_to "#{label}#{arrow}", league_league_draft_board_path(@league, link_params), class: 'sort-link'
            end
          %>
          <% show_status = params.key?(:drafted) && params[:drafted] == "" %>

          <table>
            <thead>
              <tr>
                <th><%= sort_link.('name', 'Player') %></th>
                <th><%= sort_link.('positions', 'Pos') %></th>
                <th><%= sort_link.('mlb_team', 'Team') %></th>
                <th><%= sort_link.('calculated_value', 'Value') %></th>
                <% if show_status %><th>Status</th><% end %>
                <!-- Hitter Stats -->
                <th><%= sort_link.('at_bats', 'AB') %></th>
                <th><%= sort_link.('runs', 'R') %></th>
                <th><%= sort_link.('home_runs', 'HR') %></th>
                <th><%= sort_link.('rbi', 'RBI') %></th>
                <th><%= sort_link.('stolen_bases', 'SB') %></th>
                <th><%= sort_link.('batting_average', 'AVG') %></th>
                <!-- Pitcher Stats -->
                <th><%= sort_link.('innings_pitched', 'IP') %></th>
                <th><%= sort_link.('wins', 'W') %></th>
                <th><%= sort_link.('saves', 'SV') %></th>
                <th><%= sort_link.('strikeouts', 'K') %></th>
                <th><%= sort_link.('era', 'ERA') %></th>
                <th><%= sort_link.('whip', 'WHIP') %></th>
              </tr>
            </thead>
            <tbody id="player-database-list">
              <%= render partial: "draft_board/player_database_table", locals: { players: @players, league_id: @league.id, show_status: show_status } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Error display area -->
      <div id="draft-error"></div>

      <!-- Draft Player Modal -->
      <div class="modal hidden" data-draft-modal-target="modal" data-action="click->draft-modal#closeOnOutsideClick">
        <div class="modal-content modal-wide">
          <div class="modal-header">
            <h3 class="modal-title">
              Draft Player:
              <span data-draft-modal-target="playerName"></span>
              <a href="#"
                 target="_blank"
                 rel="noopener noreferrer"
                 data-draft-modal-target="googleSearchLink"
                 style="font-size: 0.6em; margin-left: 0.5rem; font-weight: normal; text-decoration: none;">
                🔍 <span style="text-decoration: underline;">search</span>
              </a>
            </h3>
            <button class="modal-close" data-action="click->draft-modal#close" type="button">
              ×
            </button>
          </div>

          <div class="modal-body">
            <%= form_with url: draft_picks_path, method: :post, data: { action: "submit->draft-modal#submit", turbo: true } do |f| %>
              <input type="hidden" name="draft_pick[player_id]" data-draft-modal-target="playerId">
              <input type="hidden" name="draft_pick[league_id]" value="<%= @league.id %>">
              <input type="hidden" name="draft_pick[is_keeper]" value="false">
              <input type="hidden" name="draft_pick[is_topped]" value="0">
              <%= hidden_field_tag :search, params[:search] %>
              <%= hidden_field_tag :position, params[:position] %>
              <%= hidden_field_tag :drafted, params.key?(:drafted) ? params[:drafted] : "false" %>
              <%= hidden_field_tag :interested, params[:interested] %>
              <%= hidden_field_tag :min_value, params[:min_value] %>
              <%= hidden_field_tag :sort, params[:sort] %>
              <%= hidden_field_tag :direction, params[:direction] %>

              <div class="modal-body-columns">
                <!-- Left: Draft Form -->
                <div class="modal-col-form">
                  <div class="form-group">
                    <label for="draft-team">Drafting Team</label>
                    <select
                      id="draft-team"
                      name="draft_pick[team_id]"
                      data-draft-modal-target="teamSelect"
                      required
                    >
                      <option value="">-- Select Team --</option>
                      <%
                        total_roster_spots = (@league.roster_config || {}).values.sum
                      %>
                      <% @teams.each do |team| %>
                        <%
                          remaining_spots = total_roster_spots - team.draft_picks.count
                          max_bid = remaining_spots > 1 ? team.budget_remaining - (remaining_spots - 1) : team.budget_remaining
                        %>
                        <option value="<%= team.id %>">
                          <%= team.name %> (max bid $<%= max_bid %>)
                        </option>
                      <% end %>
                    </select>
                  </div>

                  <div class="form-group">
                    <label for="draft-position">Draft Position</label>
                    <select
                      id="draft-position"
                      name="draft_pick[drafted_position]"
                      data-draft-modal-target="positionSelect"
                      required
                    >
                    </select>
                  </div>

                  <div class="form-group">
                    <label for="draft-price">Draft Price ($)</label>
                    <input
                      type="number"
                      id="draft-price"
                      name="draft_pick[price]"
                      data-draft-modal-target="priceInput"
                      min="1"
                      max="<%= @league.auction_budget %>"
                      required
                    >
                  </div>

                  <div class="form-group">
                    <label>
                      <input type="checkbox" name="draft_pick[is_topped]" value="1" data-draft-modal-target="toppedCheckbox">
                      Topped
                    </label>
                  </div>
                </div>

                <!-- Right: Player Details -->
                <div class="modal-col-details">
                  <div class="player-details">
                    <div class="player-details-row">
                      <span class="player-details-label">Position(s):</span>
                      <span class="player-details-value" data-draft-modal-target="playerPosition"></span>
                    </div>
                    <div class="player-details-row">
                      <span class="player-details-label">Value:</span>
                      <span class="player-details-value" data-draft-modal-target="playerValue"></span>
                    </div>
                    <div class="player-details-row" style="display: block;">
                      <span class="player-details-label">Notes:</span>
                      <textarea
                        data-draft-modal-target="playerNotes"
                        data-action="change->draft-modal#saveNotes"
                        rows="3"
                        style="width: 100%; font-size: 0.9em; resize: vertical; margin-top: 0.25rem;"
                        placeholder="Add notes..."
                      ></textarea>
                    </div>
                  </div>
                </div>
              </div>

              <div class="modal-footer">
                <button type="button" class="btn btn-cancel btn-sm" data-action="click->draft-modal#close">
                  Cancel
                </button>
                <button type="submit" class="btn btn-primary btn-sm">
                  Confirm Draft
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /.draft-board-main -->
</div><!-- /.draft-board-layout -->
