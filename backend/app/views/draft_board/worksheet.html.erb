<%
  total_roster_spots = @position_slots.size
  budget = @league.auction_budget

  pitcher_positions = %w[SP RP]
  hitter_slot_indices = @position_slots.each_index.select { |i| !pitcher_positions.include?(@position_slots[i]) }
  pitcher_slot_indices = @position_slots.each_index.select { |i| pitcher_positions.include?(@position_slots[i]) }

  teams_per_group = 6
  team_groups = @teams.each_slice(teams_per_group).to_a
  my_team_id = @my_team&.id

  active_positions = (@league.roster_config || {}).select { |_, slots| slots.to_i > 0 }.keys
%>

<div class="worksheet-wrap"
     data-controller="worksheet-draft-modal"
     data-worksheet-draft-modal-active-positions-value="<%= active_positions.to_json %>">

  <% team_groups.each_with_index do |group_teams, group_index| %>
    <div class="card <%= 'mb-3' unless group_index == team_groups.size - 1 %>">
      <% if group_index == 0 %>
        <h2 class="card-title"><%= @league.name %> - Auction Worksheet</h2>
      <% end %>

      <table class="worksheet-table" style="font-size: 0.85em; width: 100%;">
        <colgroup>
          <col style="width: 55px;">
          <% group_teams.each do %>
            <col style="width: 40px;">
            <col>
          <% end %>
        </colgroup>
        <thead>
          <tr>
            <th>Pos</th>
            <% group_teams.each do |team| %>
              <th colspan="2" style="text-align: center; border-left: 2px solid var(--border-color); <%= 'background: rgba(255, 220, 50, 0.3);' if team.id == my_team_id %>">
                <%= link_to team.name, team_path(team) %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @position_slots.each_with_index do |position, slot_index| %>
            <% same_pos_index = @position_slots[0...slot_index].count(position) %>
            <tr>
              <td><strong><%= position %></strong></td>
              <% group_teams.each do |team| %>
                <%
                  picks = @team_rosters[team.id][position] || []
                  pick = picks[same_pos_index]
                  topped_bg = pick&.is_topped ? 'background: rgba(255, 220, 50, 0.15);' : ''
                %>
                <% if pick %>
                  <td style="border-left: 2px solid var(--border-color); text-align: right; <%= topped_bg %>">
                    <% if pick.is_keeper %><strong><% end %>$<%= pick.price %><% if pick.is_keeper %></strong><% end %>
                  </td>
                  <td style="<%= topped_bg %>">
                    <% if pick.is_keeper %><strong><% end %><%= render partial: "players/player_name", locals: { player: pick.player, draft_pick: pick } %><% if pick.is_keeper %></strong><% end %>
                  </td>
                <% else %>
                  <td class="worksheet-empty-cell"
                      style="border-left: 2px solid var(--border-color);"
                      data-action="click->worksheet-draft-modal#open"
                      data-team-id="<%= team.id %>"
                      data-team-name="<%= team.name %>"
                      data-position="<%= position %>"
                      data-league-id="<%= @league.id %>">
                  </td>
                  <td class="worksheet-empty-cell"
                      style="color: var(--text-secondary); font-size: 0.8em;"
                      data-action="click->worksheet-draft-modal#open"
                      data-team-id="<%= team.id %>"
                      data-team-name="<%= team.name %>"
                      data-position="<%= position %>"
                      data-league-id="<%= @league.id %>">
                    +
                  </td>
                <% end %>
              <% end %>
            </tr>
          <% end %>

          <!-- Summary rows -->
          <tr style="border-top: 3px solid var(--border-color);">
            <td><strong>Remaining</strong></td>
            <% group_teams.each do |team| %>
              <%
                remaining_spots = total_roster_spots - team.draft_picks.count
                max_bid = remaining_spots > 1 ? team.budget_remaining - (remaining_spots - 1) : team.budget_remaining
              %>
              <td style="border-left: 2px solid var(--border-color); text-align: right;">
                <strong>$<%= team.budget_remaining %></strong>
              </td>
              <td style="font-size: 0.9em; color: var(--text-secondary);"><%= remaining_spots %> spots, max $<%= max_bid %></td>
            <% end %>
          </tr>

          <tr>
            <td><strong>Total</strong></td>
            <% group_teams.each do |team| %>
              <% total_spent = budget - team.budget_remaining %>
              <td style="border-left: 2px solid var(--border-color); text-align: right;">
                <strong>$<%= total_spent %></strong>
              </td>
              <td style="font-size: 0.9em; color: var(--text-secondary);"><%= team.draft_picks.count %> picks</td>
            <% end %>
          </tr>

          <tr>
            <td><strong>Hitting</strong></td>
            <% group_teams.each do |team| %>
              <%
                hitting_spend = 0
                hitting_count = 0
                hitter_slot_indices.each do |i|
                  pos = @position_slots[i]
                  same_pos_idx = @position_slots[0...i].count(pos)
                  picks = @team_rosters[team.id][pos] || []
                  pick = picks[same_pos_idx]
                  if pick
                    hitting_spend += pick.price
                    hitting_count += 1
                  end
                end
              %>
              <td style="border-left: 2px solid var(--border-color); text-align: right;">$<%= hitting_spend %></td>
              <td style="font-size: 0.9em; color: var(--text-secondary);"><%= hitting_count %> players</td>
            <% end %>
          </tr>

          <tr>
            <td><strong>Pitching</strong></td>
            <% group_teams.each do |team| %>
              <%
                pitching_spend = 0
                pitching_count = 0
                pitcher_slot_indices.each do |i|
                  pos = @position_slots[i]
                  same_pos_idx = @position_slots[0...i].count(pos)
                  picks = @team_rosters[team.id][pos] || []
                  pick = picks[same_pos_idx]
                  if pick
                    pitching_spend += pick.price
                    pitching_count += 1
                  end
                end
              %>
              <td style="border-left: 2px solid var(--border-color); text-align: right;">$<%= pitching_spend %></td>
              <td style="font-size: 0.9em; color: var(--text-secondary);"><%= pitching_count %> players</td>
            <% end %>
          </tr>

          <tr>
            <td><strong>% Split</strong></td>
            <% group_teams.each do |team| %>
              <%
                total_spent = budget - team.budget_remaining
                hitting_spend = 0
                hitter_slot_indices.each do |i|
                  pos = @position_slots[i]
                  same_pos_idx = @position_slots[0...i].count(pos)
                  picks = @team_rosters[team.id][pos] || []
                  pick = picks[same_pos_idx]
                  hitting_spend += pick.price if pick
                end
                pitching_spend = 0
                pitcher_slot_indices.each do |i|
                  pos = @position_slots[i]
                  same_pos_idx = @position_slots[0...i].count(pos)
                  picks = @team_rosters[team.id][pos] || []
                  pick = picks[same_pos_idx]
                  pitching_spend += pick.price if pick
                end
                batting_pct = total_spent > 0 ? (hitting_spend * 100.0 / total_spent).round(0) : 0
                pitching_pct = total_spent > 0 ? (pitching_spend * 100.0 / total_spent).round(0) : 0
              %>
              <td colspan="2" style="border-left: 2px solid var(--border-color); padding: 0; position: relative; height: 1.8em;">
                <% if total_spent > 0 %>
                  <div style="display: flex; height: 100%; line-height: 1.8em; font-size: 0.85em;">
                    <div style="width: <%= batting_pct %>%; background: rgba(59, 130, 246, 0.35); text-align: center; color: var(--text-primary);"
                         title="Batting: $<%= hitting_spend %> (<%= batting_pct %>%)">
                      <% if batting_pct >= 20 %><%= batting_pct %>%<% end %>
                    </div>
                    <div style="width: <%= pitching_pct %>%; background: rgba(249, 115, 22, 0.35); text-align: center; color: var(--text-primary);"
                         title="Pitching: $<%= pitching_spend %> (<%= pitching_pct %>%)">
                      <% if pitching_pct >= 20 %><%= pitching_pct %>%<% end %>
                    </div>
                  </div>
                <% end %>
              </td>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
  <% end %>

  <!-- Worksheet Draft Modal -->
  <div class="modal hidden"
       data-worksheet-draft-modal-target="modal"
       data-action="click->worksheet-draft-modal#closeOnOutsideClick">
    <div class="modal-content modal-wide">
      <div class="modal-header">
        <h3 class="modal-title" data-worksheet-draft-modal-target="modalTitle">Draft Player</h3>
        <button class="modal-close" data-action="click->worksheet-draft-modal#close" type="button">×</button>
      </div>

      <div class="modal-body">
        <%= form_with url: draft_picks_path, method: :post, data: { action: "submit->worksheet-draft-modal#submit", turbo: true } do |f| %>
          <input type="hidden" name="draft_pick[player_id]"  data-worksheet-draft-modal-target="playerIdInput">
          <input type="hidden" name="draft_pick[team_id]"    data-worksheet-draft-modal-target="teamIdInput">
          <input type="hidden" name="draft_pick[league_id]"  data-worksheet-draft-modal-target="leagueIdInput">
          <input type="hidden" name="draft_pick[is_keeper]"  value="false">
          <input type="hidden" name="draft_pick[is_topped]"  value="0">

          <div class="modal-body-columns">
            <!-- Left: Search -->
            <div class="modal-col-form">
              <div class="form-group">
                <label>Search Player</label>
                <input type="text"
                       class="form-control"
                       placeholder="Type player name..."
                       autocomplete="off"
                       data-worksheet-draft-modal-target="searchInput"
                       data-action="input->worksheet-draft-modal#search">
              </div>

              <div data-worksheet-draft-modal-target="searchResults" class="player-search-results"></div>
            </div>

            <!-- Right: Draft details + selected player -->
            <div class="modal-col-details">
              <div class="form-group">
                <label>Draft Position</label>
                <select name="draft_pick[drafted_position]"
                        class="form-control"
                        data-worksheet-draft-modal-target="positionSelect">
                </select>
              </div>

              <div class="form-group">
                <label>Draft Price ($)</label>
                <input type="number"
                       name="draft_pick[price]"
                       class="form-control"
                       min="1"
                       max="<%= @league.auction_budget %>"
                       data-worksheet-draft-modal-target="priceInput">
              </div>

              <div class="form-group">
                <label>
                  <input type="checkbox" name="draft_pick[is_topped]" value="1"
                         data-worksheet-draft-modal-target="toppedCheckbox">
                  Topped
                </label>
              </div>

              <!-- Selected player chip -->
              <div class="worksheet-selected-player worksheet-selected-player--empty"
                   data-worksheet-draft-modal-target="selectedPlayerName">&nbsp;</div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-cancel btn-sm"
                    data-action="click->worksheet-draft-modal#close">
              Cancel
            </button>
            <button type="submit" class="btn btn-primary btn-sm">
              Confirm Draft
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>
