<%# Player database table row
    For non-drafted players, the entire row is clickable to toggle interest.
%>
<tr id="player-row-<%= player.id %>"
    class="<%= 'player-row-interested' if player.interested? %> <%= 'player-row-priority' if player.priority? %>"
    <% unless player.is_drafted %>
      data-controller="player-interest"
      data-action="click->player-interest#toggle"
    <% end %>>
  <td>
    <% if player.is_drafted %>
      <strong><%= player.name %></strong>
    <% else %>
      <a href="#"
         data-action="click->draft-modal#open"
         data-player-id="<%= player.id %>"
         data-player-name="<%= player.name %>"
         data-player-positions="<%= player.positions %>"
         data-player-mlb-team="<%= player.mlb_team %>"
         data-player-value="<%= player.calculated_value&.round || '?' %>"
         class="player-link">
        <strong><%= player.name %></strong>
      </a>
    <% end %>
  </td>
  <td><%= player.positions %></td>
  <td><%= player.mlb_team %></td>
  <td><strong>$<%= player.calculated_value&.round || "?" %></strong></td>
  <td>
    <% if player.is_drafted %>
      <span class="badge badge-warning">Drafted</span>
    <% else %>
      <span class="badge badge-success">Available</span>
    <% end %>
  </td>
  <%= render "players/stats_columns", player: player %>
  <td>
    <% unless player.is_drafted %>
      <%= form_with url: toggle_interested_player_path(player, league_id: league_id), method: :post,
                    data: { turbo: true, player_interest_target: "form" } do %>
      <% end %>
    <% end %>
  </td>
</tr>
