<%# Shared Turbo Stream updates for draft board
    Updates all draft board sections after a draft pick is created or destroyed.

    Params:
    - draft_picks: Array of DraftPick objects to display
    - teams: Array of Team objects for budget display
    - players: Array of filtered Player objects for main database table (optional)
    - league_id: ID of current league (optional, required if players provided)
    - clear_errors: Boolean (default: false) - whether to clear error messages
%>

<%# Update the draft picks list %>
<%= turbo_stream.replace "draft-picks" do %>
  <%= render partial: "draft_board/draft_picks_table", locals: { draft_picks: draft_picks } %>
<% end %>

<%# Update the main player database table (if filters were applied) %>
<% if local_assigns[:players].present? && local_assigns[:league_id].present? %>
  <%= turbo_stream.update "player-database-list" do %>
    <%= render partial: "draft_board/player_database_table", locals: { players: players, league_id: league_id } %>
  <% end %>
<% end %>

<%# Update team budgets %>
<%= turbo_stream.update "team-budgets" do %>
  <%= render partial: "draft_board/team_budgets", locals: { teams: teams } %>
<% end %>

<% if local_assigns.fetch(:clear_errors, false) %>
  <%# Clear any error messages %>
  <%= turbo_stream.update "draft-error", "" %>
<% end %>
