<div class="mb-2">
  <%= link_to "← Back to Draft Board", league_league_draft_board_path(@league), class: "btn btn-sm" %>
</div>

<div class="card mb-3">
  <h2 class="card-title"><%= @league.name %> - Draft Analyzer</h2>
  <p class="text-muted">
    Real-time insights and analytics to inform your draft strategy
  </p>
</div>

<!-- Your Team Selector -->
<div class="card mb-3 team-selector">
  <%= form_with url: league_league_draft_analyzer_path(@league), method: :get, local: true, class: "team-selector-form" do |f| %>
    <label for="my_team" class="team-selector-label">Your Team</label>
    <div class="team-selector-controls">
      <select name="my_team" id="my_team" class="team-selector-select" onchange="this.form.submit()">
        <option value="">Select your team...</option>
        <% @teams.each do |team| %>
          <option value="<%= team.id %>" <%= "selected" if @my_team&.id == team.id %>><%= team.name %></option>
        <% end %>
      </select>
      <% if @my_team %>
        <span class="team-selector-active">Showing suggestions for <strong><%= @my_team.name %></strong></span>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Spending Split -->
<div class="card mb-3" data-controller="collapsible" data-collapsible-key="spendingSplitCollapsed">
  <div class="collapsible-header" data-action="click->collapsible#toggle">
    <h3 class="card-title">Spending Split: Batting vs Pitching</h3>
    <button type="button" class="collapsible-toggle" data-collapsible-target="icon">▼</button>
  </div>

  <div class="collapsible-content" data-collapsible-target="content">
    <p class="text-muted mb-3">
      How each team is allocating their budget between batting and pitching.
    </p>

    <% max_spend = @spending_splits.map { |s| s[:total_spend] }.max.to_i %>
    <% budget = @league.auction_budget %>

    <div class="spending-split-chart">
      <% @spending_splits.each do |data| %>
        <div class="spending-row">
          <div class="spending-team-name">
            <%= link_to data[:team].name, team_path(data[:team]) %>
          </div>
          <div class="spending-bar-container">
            <% bar_width = budget > 0 ? (data[:total_spend].to_f / budget * 100) : 0 %>
            <div class="spending-bar" style="width: <%= bar_width %>%;">
              <% if data[:batting_spend] > 0 %>
                <div class="spending-segment spending-batting" style="width: <%= data[:batting_pct] %>%;"
                     title="Batting: $<%= data[:batting_spend] %> (<%= data[:batting_pct] %>%)">
                  <% if data[:batting_pct] >= 15 %>
                    <span>$<%= data[:batting_spend] %></span>
                  <% end %>
                </div>
              <% end %>
              <% if data[:pitching_spend] > 0 %>
                <div class="spending-segment spending-pitching" style="width: <%= data[:pitching_pct] %>%;"
                     title="Pitching: $<%= data[:pitching_spend] %> (<%= data[:pitching_pct] %>%)">
                  <% if data[:pitching_pct] >= 15 %>
                    <span>$<%= data[:pitching_spend] %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="spending-remaining" style="width: <%= 100 - bar_width %>%;"
                 title="Remaining: $<%= data[:remaining] %>">
            </div>
          </div>
          <div class="spending-total">
            $<%= data[:total_spend] %>/<%= budget %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-3 pt-3" style="border-top: 1px solid var(--border-color);">
      <p class="text-sm text-muted">
        <span class="spending-legend-swatch spending-batting"></span> Batting &nbsp;
        <span class="spending-legend-swatch spending-pitching"></span> Pitching &nbsp;
        <span class="spending-legend-swatch spending-remaining-swatch"></span> Remaining
      </p>
    </div>
  </div>
</div>

<!-- Roster Fill Rate by Position -->
<div data-controller="teams-can-draft-modal">
  <div class="card" data-controller="collapsible" data-collapsible-key="rosterFillRateCollapsed">
    <div class="collapsible-header" data-action="click->collapsible#toggle">
      <h3 class="card-title">Roster Fill Rate by Position</h3>
      <button type="button" class="collapsible-toggle" data-collapsible-target="icon">▼</button>
    </div>

    <div class="collapsible-content" data-collapsible-target="content">
    <p class="text-muted mb-3">
      League-wide availability for each roster position. Shows how many slots remain across all teams.
    </p>

    <div style="max-height: 520px; overflow-y: auto;">
      <table>
        <thead>
          <tr>
            <th>Position</th>
            <th>Total Slots</th>
            <th>Filled</th>
            <th>Available</th>
            <th>Fill %</th>
            <th>Teams Can Draft</th>
          </tr>
        </thead>
        <tbody>
          <% @position_fill_rates.each do |data| %>
            <tr>
              <td><strong><%= data[:position] %></strong></td>
              <td><%= data[:total_slots] %></td>
              <td><%= data[:filled_slots] %></td>
              <td>
                <strong>
                  <%= data[:available_slots] %>
                </strong>
              </td>
              <td>
                <span class="badge <%= data[:fill_percentage] >= 75 ? 'badge-warning' : 'badge-info' %>">
                  <%= data[:fill_percentage] %>%
                </span>
              </td>
              <td>
                <button
                  class="btn btn-sm"
                  data-action="click->teams-can-draft-modal#show"
                  data-position="<%= data[:position] %>"
                  data-teams="<%= data[:teams_can_draft].map { |t| { id: t.id, name: t.name } }.to_json %>"
                  data-teams-cant-draft="<%= data[:teams_cant_draft].map { |d| { id: d[:team].id, name: d[:team].name, blockers: d[:blocking_players] } }.to_json %>"
                >
                  <%= data[:teams_can_draft_count] %> / <%= @teams.count %>
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-3 pt-3" style="border-top: 1px solid var(--border-color);">
      <p class="text-sm text-muted">
        <strong>Position Eligibility Notes:</strong><br>
        • UTIL can be filled by any player (batters and pitchers)<br>
        • MI (Middle Infield) can be filled by 2B or SS<br>
        • CI (Corner Infield) can be filled by 1B or 3B
      </p>
    </div>
  </div>
  </div>

  <!-- Teams Can Draft Modal -->
  <div class="modal hidden" data-teams-can-draft-modal-target="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Teams Who Can Draft <span data-teams-can-draft-modal-target="position"></span></h3>
        <button
          type="button"
          class="modal-close"
          data-action="click->teams-can-draft-modal#close"
        >
          ×
        </button>
      </div>

      <div class="modal-body">
        <p class="text-muted text-sm mb-3">
          These teams can draft this position either because they have an open slot, or they have a player in a flex position (UTIL/MI/CI) who can be moved to make room.
        </p>
        <div data-teams-can-draft-modal-target="teamsList"></div>

        <div data-teams-can-draft-modal-target="cantDraftSection" style="display: none;">
          <h4 style="margin-top: 1rem; margin-bottom: 0.5rem; color: #999; font-size: 0.9em;">Can't Draft</h4>
          <div data-teams-can-draft-modal-target="cantDraftList"></div>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-sm" data-action="click->teams-can-draft-modal#close">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Team Needs Matrix -->
<div class="card mt-3" data-controller="collapsible" data-collapsible-key="teamNeedsMatrixCollapsed">
  <div class="collapsible-header" data-action="click->collapsible#toggle">
    <h3 class="card-title">Team Needs Matrix</h3>
    <button type="button" class="collapsible-toggle" data-collapsible-target="icon">▼</button>
  </div>

  <div class="collapsible-content" data-collapsible-target="content">
    <p class="text-muted mb-3">
      Per-team position availability. Green = open slots, Yellow = can draft via roster move, Gray = cannot draft.
    </p>

    <div style="overflow-x: auto;">
      <table class="team-needs-matrix">
        <thead>
          <tr>
            <th>Team</th>
            <% @team_needs_matrix[:positions].each do |pos| %>
              <th class="text-center"><%= pos %></th>
            <% end %>
            <th class="text-center">Roster</th>
          </tr>
        </thead>
        <tbody>
          <% @team_needs_matrix[:teams].each do |team_data| %>
            <tr>
              <td>
                <%= link_to team_data[:team].name, team_path(team_data[:team]), class: "player-link" %>
              </td>
              <% @team_needs_matrix[:positions].each do |pos| %>
                <% cell = team_data[:needs][pos] %>
                <% case cell[:state] %>
                <% when :open %>
                  <td class="needs-cell needs-open text-center"><%= cell[:open_slots] %></td>
                <% when :flex %>
                  <td class="needs-cell needs-flex text-center">&#10003;</td>
                <% when :closed %>
                  <td class="needs-cell needs-closed text-center">&mdash;</td>
                <% end %>
              <% end %>
              <td class="text-center">
                <span class="badge <%= team_data[:total_filled] >= team_data[:total_slots] ? 'badge-warning' : 'badge-info' %>">
                  <%= team_data[:total_filled] %>/<%= team_data[:total_slots] %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-3 pt-3" style="border-top: 1px solid var(--border-color);">
      <p class="text-sm text-muted">
        <span class="needs-cell needs-open" style="display: inline-block; padding: 0.1rem 0.5rem; font-size: 0.75rem;">3</span> Open slots &nbsp;
        <span class="needs-cell needs-flex" style="display: inline-block; padding: 0.1rem 0.5rem; font-size: 0.75rem;">&#10003;</span> Can draft via roster move &nbsp;
        <span class="needs-cell needs-closed" style="display: inline-block; padding: 0.1rem 0.5rem; font-size: 0.75rem;">&mdash;</span> Cannot draft
      </p>
    </div>
  </div>
</div>

<!-- Nomination Suggestions -->
<div class="card mt-3" data-controller="collapsible" data-collapsible-key="nominationSuggestionsCollapsed">
  <div class="collapsible-header" data-action="click->collapsible#toggle">
    <h3 class="card-title">Nomination Suggestions</h3>
    <button type="button" class="collapsible-toggle" data-collapsible-target="icon">▼</button>
  </div>

  <div class="collapsible-content" data-collapsible-target="content">
    <% if @my_team.nil? %>
      <p class="text-muted">
        Select your team above to get strategic nomination suggestions. The algorithm ranks available players
        by how effectively they drain opponent budgets without helping your roster.
      </p>
    <% elsif @nomination_suggestions.empty? %>
      <p class="text-muted">
        No nomination suggestions available. This can happen when there are no available players with value above $1,
        or when no opponents need any remaining positions.
      </p>
    <% else %>
      <p class="text-muted mb-3">
        Players ranked by nomination value &mdash; nominate these to drive up bidding among opponents while keeping your budget safe.
      </p>

      <div style="max-height: 600px; overflow-y: auto;">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Player</th>
              <th>Pos</th>
              <th>Value ($)</th>
              <th>Demand</th>
              <th>Reasons</th>
            </tr>
          </thead>
          <tbody>
            <% @nomination_suggestions.each_with_index do |suggestion, index| %>
              <tr>
                <td><span class="nomination-rank"><%= index + 1 %></span></td>
                <td><strong><%= suggestion[:player].name %></strong></td>
                <td><%= suggestion[:player].positions %></td>
                <td>$<%= suggestion[:player].calculated_value.to_i %></td>
                <td>
                  <span class="badge <%= suggestion[:opponent_demand] >= 0.5 ? 'badge-warning' : 'badge-info' %>">
                    <%= (suggestion[:opponent_demand] * 100).round(0) %>%
                  </span>
                </td>
                <td>
                  <% suggestion[:reasons].each do |reason| %>
                    <% if reason.include?("don't need") || reason.include?("opponents need") %>
                      <span class="reason-tag reason-tag-good"><%= reason %></span>
                    <% elsif reason.include?("you also need") %>
                      <span class="reason-tag reason-tag-warn"><%= reason %></span>
                    <% else %>
                      <span class="reason-tag"><%= reason %></span>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
